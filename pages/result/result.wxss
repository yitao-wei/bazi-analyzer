/* pages/result/result.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #fafafa;
  font-family: 'PingFang SC', 'Helvetica Neue', STHeiti, 'Microsoft Yahei', sans-serif;
  padding: 20px;
}

.header {
  text-align: center;
  margin-bottom: 20px;
}

.title {
  font-size: 20px;
  font-weight: bold;
  color: #333333;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #555555;
  margin-bottom: 10px;
}

.bazi-section, .wuxing-section, .tags-section, .advice-section {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.bazi-display {
  font-size: 16px;
  color: #333333;
  text-align: center;
}

.chart {
  width: 100%;
  height: 200px;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background-color: #e8f5e8;
  color: #2e7d32;
  padding: 5px 10px;
  border-radius: 15px;
  margin: 5px;
  font-size: 14px;
}

.advice-item {
  margin-bottom: 10px;
}

.advice-text {
  font-size: 14px;
  color: #666666;
  line-height: 1.5;
}

.footer {
  margin-top: auto;
  text-align: center;
}

.back-btn {
  width: 60%;
  height: 45px;
  background-color: #c62828;
  color: #ffffff;
  border-radius: 22px;
  font-size: 16px;
  border: none;
}

.back-btn:active {
  background-color: #ad1457;
}