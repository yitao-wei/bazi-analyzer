<view class="container">
  <!-- 顶部显示当前时间的天干地支 -->
  <view class="top-section">
    <text class="current-time">{{currentBazi}}</text>
  </view>

  <!-- 中间输入表单 -->
  <view class="form-section">
    <view class="input-group">
      <text class="label">出生日期：</text>
      <view class="date-time-picker">
        <!-- 日期选择器 -->
        <picker mode="multiSelector" value="{{selectedDate}}" range="{{[yearOptions, monthOptions, dayOptions]}}" bindchange="onDateChange">
          <view class="picker-display">{{birthDate || '请选择出生日期'}}</view>
        </picker>
      </view>
      <text class="label">出生时间：</text>
      <view class="time-picker">
        <!-- 时间选择器 -->
        <picker mode="selector" range="{{timeOptions}}" value="{{birthTimeIndex}}" bindchange="onTimeChange">
          <view class="picker-display">{{birthTime || '请选择出生时辰'}}</view>
        </picker>
      </view>
      <view class="calendar-switch">
        <radio-group class="calendar-radio" bindchange="onCalendarChange">
          <label class="radio-label">
            <radio value="false" checked="{{!isLunar}}"/>公历
          </label>
          <label class="radio-label">
            <radio value="true" checked="{{isLunar}}"/>农历
          </label>
        </radio-group>
      </view>
    </view>

    <view class="input-group">
      <text class="label">出生地：</text>
      <picker mode="region" value="{{[provincename,cityname,districtname]}}" bindchange="onAddressChange">
      <view style="margin-left:29%;" wx:if="{{provincename}}">{{provincename+' '+cityname+' '+districtname}}</view>
      <view style="margin-left:35%;" wx:else>选择所在地区</view>
      </picker>
    </view>

    <view class="input-group">
      <text class="label">性别：</text>
      <radio-group class="gender-radio" bindchange="onGenderChange">
        <label class="radio-label">
          <radio value="1" checked="{{gender === '1'}}"/>男
        </label>
        <label class="radio-label">
          <radio value="2" checked="{{gender === '2'}}"/>女
        </label>
      </radio-group>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-section">
    <button class="submit-btn" bindtap="onSubmit">查阅生辰八字</button>
  </view>
</view>